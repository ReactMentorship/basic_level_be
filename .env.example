# Copy to .env and adjust as needed. All values are optional.

# Server
HOST=0.0.0.0
PORT=8000

# Auth / JWT
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Default seeded user
SEED_USERNAME=admin
SEED_PASSWORD=admin123
